{
  "manifest_version": 3,
  "name": "公众号留言抓取",
  "version": "0.1.0",
  "description": "抓取微信公众号文章留言，含已屏蔽评论",
  "permissions": ["tabs", "scripting", "storage"],
  "host_permissions": [
    "https://mp.weixin.qq.com/*"
  ],
  "background": {
    "service_worker": "background/index.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "留言抓取"
  },
  "content_scripts": [
    {
      "matches": ["https://mp.weixin.qq.com/misc/appmsgcomment*"],
      "js": ["articleList/index.js", "comments/index.js"]
    },
    {
      "matches": ["https://mp.weixin.qq.com/misc/appmsgcomment*"],
      "js": ["interceptor/index.js"],
      "world": "MAIN",
      "run_at": "document_start"
    }
  ]
}
